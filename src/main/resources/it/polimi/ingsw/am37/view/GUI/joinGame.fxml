<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<VBox prefHeight="403.0" prefWidth="525.0" styleClass="anchor" stylesheets="@loginStyle.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="it.polimi.ingsw.am37.view.GUI.controllers.JoinGameController">
   <children>
      <VBox alignment="CENTER" prefHeight="114.0" prefWidth="451.0">
         <children>
            <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Join Game" wrappingWidth="238.9312334060669">
               <font>
                  <Font name="System Bold" size="48.0" />
               </font>
            </Text>
         </children>
      </VBox>
      <HBox alignment="CENTER" prefHeight="242.0" prefWidth="573.0">
         <children>
            <VBox alignment="CENTER" prefHeight="215.0" prefWidth="274.0">
               <children>
                  <HBox prefHeight="215.0" prefWidth="262.0">
                     <children>
                        <ListView fx:id="lobbyList" prefHeight="215.0" prefWidth="230.0" />
                        <Region prefHeight="215.0" prefWidth="9.0" />
                        <Button fx:id="refresh" mnemonicParsing="false" onAction="#refreshClicked" text="🔄" />
                     </children>
                  </HBox>
               </children>
            </VBox>
            <VBox prefHeight="215.0" prefWidth="190.0" spacing="10.0">
               <children>
                  <Text fx:id="waitingText" strokeType="OUTSIDE" strokeWidth="0.0" text="Waiting for server response" wrappingWidth="147.73674964904785" />
                  <HBox prefHeight="26.0" prefWidth="150.0">
                     <children>
                        <Text fx:id="lobbyText" strokeType="OUTSIDE" strokeWidth="0.0" text="Lobby Selected: " />
                        <Text fx:id="lobbySelected" strokeType="OUTSIDE" strokeWidth="0.0" />
                     </children>
                  </HBox>
                  <TextField fx:id="nicknameSelected" prefHeight="22.0" prefWidth="189.0" promptText="Nickname" />
               </children>
               <padding>
                  <Insets right="40.0" />
               </padding>
            </VBox>
         </children>
      </HBox>
      <AnchorPane prefHeight="127.0" prefWidth="526.0">
         <children>
            <HBox alignment="CENTER" prefHeight="100.0" prefWidth="525.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
               <children>
                  <Button fx:id="joinGame" alignment="CENTER" contentDisplay="CENTER" mnemonicParsing="false" onAction="#joinGameClick" prefHeight="55.0" prefWidth="107.0" style="-fx-background-color: seagreen;" text="Join Game!">
                     <font>
                        <Font size="14.0" />
                     </font>
                  </Button>
                  <Region prefHeight="100.0" prefWidth="96.0" />
                  <Button fx:id="createGame" alignment="CENTER" contentDisplay="CENTER" mnemonicParsing="false" onAction="#createGameClick" prefHeight="55.0" prefWidth="107.0" text="Create Game">
                     <font>
                        <Font size="14.0" />
                     </font>
                  </Button>
               </children>
            </HBox>
         </children>
      </AnchorPane>
   </children>
</VBox>
