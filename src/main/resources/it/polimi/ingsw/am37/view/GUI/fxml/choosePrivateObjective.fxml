                                    <children>
                                        <Button fx:id="frontButton" mnemonicParsing="false" text="Front" />
                                    </children>
                                </HBox>
                                <ImageView fx:id="backStartCard" fitHeight="150.0" fitWidth="200.0" pickOnBounds="true" preserveRatio="true" />
                                <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0">
                                    <children>
                                        <Button fx:id="backButton" mnemonicParsing="false" text="Back" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                        <VBox alignment="CENTER">
                            <children>
                                <HBox spacing="5.0">
                                    <children>
                                        <ImageView fx:id="topResourceDeck" fitHeight="150.0" fitWidth="200.0" pickOnBounds="true" preserveRatio="true" />
                                        <ImageView fx:id="resourceCard1" fitHeight="150.0" fitWidth="200.0" pickOnBounds="true" preserveRatio="true" />
                                        <ImageView fx:id="resourceCard2" fitHeight="150.0" fitWidth="200.0" pickOnBounds="true" preserveRatio="true" />
                                    </children>
                           <padding>
                              <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
                           </padding>
                                </HBox>
                                <HBox spacing="5.0">
                                    <children>
                                        <ImageView fx:id="topGoldDeck" fitHeight="150.0" fitWidth="200.0" pickOnBounds="true" preserveRatio="true" />
                                        <ImageView fx:id="goldCard1" fitHeight="150.0" fitWidth="200.0" pickOnBounds="true" preserveRatio="true" />
                                        <ImageView fx:id="goldCard2" fitHeight="150.0" fitWidth="200.0" pickOnBounds="true" preserveRatio="true" />
                                    </children>
                           <padding>
                              <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
                           </padding>
                                </HBox>
                        <VBox prefHeight="200.0" prefWidth="100.0" spacing="5.0">
                           <children>
                              <Label text="Your Hand" />
                              <HBox spacing="5.0">
                                 <children>
                                    <ImageView fx:id="playerResourceCard1" fitHeight="150.0" fitWidth="200.0" pickOnBounds="true" preserveRatio="true" />
                                    <ImageView fx:id="playerResourceCard2" fitHeight="150.0" fitWidth="200.0" pickOnBounds="true" preserveRatio="true" />
                                    <ImageView fx:id="playerGoldCard" fitHeight="150.0" fitWidth="200.0" pickOnBounds="true" preserveRatio="true" />
                                 </children>
