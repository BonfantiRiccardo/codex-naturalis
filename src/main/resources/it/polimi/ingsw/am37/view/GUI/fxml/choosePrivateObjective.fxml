                                 </padding>
                              </HBox>
                           </children>
                           <padding>
                              <Insets bottom="5.0" left="50.0" right="5.0" top="5.0" />
                           </padding>
                        </VBox>
                            </children>
                        </VBox>
                    </children>
                </HBox>
                <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0" spacing="30.0">
                    <children>
                        <Button fx:id="confirmButton" mnemonicParsing="false" text="Confirm!" />
                        <Text fx:id="errorText" strokeType="OUTSIDE" strokeWidth="0.0" />
                    </children>
                    <padding>
                        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
                    </padding>
                </HBox>
            </children>
        </VBox>
